{
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/dist/index.html" }
  ],
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false
}
