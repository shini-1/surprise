{
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/dist/index.html" }
  ],
  "buildCommand": "cd frontend && npm install && npm run build && cd .. && rm -rf dist && mv frontend/dist dist",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false
}