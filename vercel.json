{
  "buildCommand": "reflex export",
  "outputDirectory": "public",
  "serverlessFunctionRegion": "us-east-1",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}